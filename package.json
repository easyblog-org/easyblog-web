    "nuxt": "^3.11.0",
    "pinia": "^2.1.7",
    "postcss": "^8.5.13",
    "tailwindcss": "^3.4.19",
    "ufo": "^1.6.4",
    "vditor": "^3.7.7",
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^17.1.2",
    "@commitlint/config-conventional": "^17.1.0",
    "eslint": "^8.24.0",
